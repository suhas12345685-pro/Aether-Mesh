# ============================================================================
# Aether Mesh — unified environment for all layers
# Copy to .env and fill in.  Every value has a safe default for local dev;
# the *_REAL toggles flip a layer from "structured stub" to live integration.
# ============================================================================

# ---- Global ---------------------------------------------------------------
NODE_ENV=development           # set to "production" to enforce secrets below
LOG_JSON=true                  # structured JSON logs for Node services (false = human)
LOG_LEVEL=info                 # debug | info | warn | error
AETHER_LOG_JSON=true           # JSON logs for the Python core
# Master key for encryption-at-rest (BYOB keys, tenant tokens). REQUIRED in
# production. 64-hex-char = raw 32-byte key, otherwise treated as a passphrase.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AETHER_SECRET_KEY=

# ---- Tenancy -------------------------------------------------------------
AETHER_TENANT_ID=demo
AETHER_PROFILE=power            # lite (phone, 180s heartbeat) | power (desktop, 60s)
AETHER_WORKSPACE=./workspace

# ---- Brain: Hermes (OpenAI-compatible) -----------------------------------
# Start Hermes with API_SERVER_ENABLED=true, then `hermes gateway`.
HERMES_API_BASE=http://localhost:8642/v1
HERMES_API_KEY=changeme
HERMES_MODEL=hermes            # BYOB: whatever model Hermes is configured to route to

# ---- Channels: OpenClaw gateway ------------------------------------------
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_CMD=openclaw          # CLI fallback transport
OPENCLAW_TOKEN=
# comma-separated conversation/channel ids to watch; empty = all
AETHER_WATCH_CHANNELS=

# ---- Body: Infrastructure layer (Node service) ---------------------------
INFRA_API_BASE=http://localhost:8090
INFRA_PORT=8090
INFRA_DB_FILE=./data/infra.db
# Admin token the PLATFORM uses to call /provision. Unset = OPEN dev mode.
INFRA_ADMIN_TOKEN=
# Per-tenant token the Aether Core WORKER uses for capability calls. In
# production a supervisor pulls this from /api/customers/:id/worker-config.
INFRA_API_TOKEN=
# VM (Docker) tenancy hardening — real mode only:
VM_MEMORY_MB=512
VM_CPUS=1
VM_PIDS_LIMIT=256
VM_NETWORK=bridge
BROWSER_MAX_SESSIONS=25

# Twilio (phone identity).  INFRA_TWILIO_REAL=false => provisioning is simulated.
INFRA_TWILIO_REAL=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_AREA_CODE=415
# Public HTTPS URL of this infra service. Required for Twilio to auto-configure
# the SMS webhook and for Mailgun routing. Leave empty in local dev.
INFRA_PUBLIC_URL=               # e.g. https://infra.aethermesh.dev

# Email identity.  INFRA_EMAIL_REAL=false => mailbox is simulated.
INFRA_EMAIL_REAL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_DOMAIN=aethermesh.dev        # legacy fallback (used for non-agent sends)
AGENT_EMAIL_DOMAIN=agent.aethermesh.dev  # MX-routed domain for agent inboxes
# AgentMail.to — preferred provider; creates a real dedicated inbox per agent.
# Get a key at https://agentmail.to — if unset, falls back to Mailgun routing.
AGENTMAIL_API_KEY=
# Mailgun API key (fallback inbound routing when AGENTMAIL_API_KEY is unset).
MAILGUN_API_KEY=

# Inbound email (Mailgun or SendGrid). INFRA_INBOUND_REAL=false => webhook
# accepted and queued, but no live MX setup is required.
INFRA_INBOUND_REAL=false
MAILGUN_WEBHOOK_SIGNING_KEY=       # Mailgun → Settings → Webhooks → Signing key
SENDGRID_INBOUND_KEY=              # optional shared secret for SendGrid

# Browser sandbox (Playwright). INFRA_BROWSER_REAL=false => no real browser launched.
INFRA_BROWSER_REAL=false

# Multi-tenant VMs (Docker).  INFRA_VM_REAL=false => containers are simulated.
INFRA_VM_REAL=false
DOCKER_HOST=                   # empty = default local docker socket
VM_IMAGE=aether/tenant-runtime:latest

# ---- B2B platform (Node service) -----------------------------------------
PLATFORM_PORT=8080
# Signs session cookies. REQUIRED in production (server refuses to boot without).
PLATFORM_SESSION_SECRET=
PLATFORM_DB_FILE=./data/platform.db
PLATFORM_PUBLIC_URL=            # https://... enables Secure cookies + HSTS
# Service-to-service admin token the SUPERVISOR uses to call the platform API.
PLATFORM_ADMIN_TOKEN=

# Agent identity (auto-populated by the platform at provisioning; override if needed)
AETHER_AGENT_NAME=                 # e.g. "Alex Chen"
AETHER_AGENT_EMAIL=                # e.g. "alex.chen@agent.aethermesh.dev"
AETHER_EMAIL_INBOUND=false         # set true to enable the email inbox channel
AETHER_AGENT_PHONE=                # e.g. "+14155551234" (auto-populated at provisioning)
AETHER_SMS_INBOUND=false           # set true once Twilio webhook is pointed at /inbound/sms

# ---- Worker supervisor ---------------------------------------------------
PLATFORM_API_BASE=http://localhost:8080
PYTHON_BIN=python              # interpreter used to launch aether_core workers
SUPERVISOR_RECONCILE_MS=30000  # how often to reconcile workers with active tenants
SUPERVISOR_HEALTH_PORT=8091    # liveness probe port

# Billing (Stripe).  PLATFORM_BILLING_REAL=false => billing is simulated.
PLATFORM_BILLING_REAL=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for Plan Tiers
STRIPE_PRICE_INTERN=
STRIPE_PRICE_MANAGER=
STRIPE_PRICE_ENTERPRISE=

# Stripe Price IDs for Cloud Deploy Add-on per Tier
STRIPE_PRICE_CLOUD_INTERN=
STRIPE_PRICE_CLOUD_MANAGER=
STRIPE_PRICE_CLOUD_ENTERPRISE=
